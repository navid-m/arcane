create forced bucket Marketing (
    ad_spend: float,
    revenue: float,
    impressions: int
);

insert into Marketing (1000.0, 5000.0, 10000);
insert into Marketing (1500.0, 7500.0, 15000);
insert into Marketing (2000.0, 10000.0, 20000);
insert into Marketing (2500.0, 12500.0, 25000);
insert into Marketing (3000.0, 15000.0, 30000);
insert into Marketing (3500.0, 17500.0, 35000);
insert into Marketing (4000.0, 20000.0, 40000);
insert into Marketing (4500.0, 22500.0, 45000);
insert into Marketing (5000.0, 25000.0, 50000);
insert into Marketing (5500.0, 27500.0, 55000);

analyze Marketing ad_spend correlation(revenue);
print "";

analyze Marketing ad_spend correlation(impressions);
print "";
