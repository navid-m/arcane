print "Creating Sales bucket with sample data...";
create forced bucket Sales (
    product: string,
    price: float,
    quantity: int,
    revenue: float,
    timestamp: int
);

insert into Sales ("Laptop", 999.99, 2, 1999.98, 1);
insert into Sales ("Mouse", 29.99, 5, 149.95, 2);
insert into Sales ("Keyboard", 79.99, 3, 239.97, 3);
insert into Sales ("Monitor", 299.99, 1, 299.99, 4);
insert into Sales ("Laptop", 999.99, 1, 999.99, 5);
insert into Sales ("Mouse", 29.99, 10, 299.90, 6);
insert into Sales ("Keyboard", 79.99, 2, 159.98, 7);
insert into Sales ("Monitor", 299.99, 2, 599.98, 8);
insert into Sales ("Laptop", 999.99, 3, 2999.97, 9);
insert into Sales ("Mouse", 29.99, 8, 239.92, 10);
insert into Sales ("Keyboard", 79.99, 1, 79.99, 11);
insert into Sales ("Monitor", 299.99, 1, 299.99, 12);
insert into Sales ("Laptop", 999.99, 2, 1999.98, 13);
insert into Sales ("Mouse", 29.99, 15, 449.85, 14);
insert into Sales ("Keyboard", 79.99, 4, 319.96, 15);

get * from Sales;

print "Real-time metrics with sliding window of 10 records";
analyze Sales revenue stream(10);
print "";

print "Trend detection, forecasting, and anomaly detection";
analyze Sales revenue timeseries;
print "";

print "Comprehensive statistics for price field";
analyze Sales price statistics;
print "";

print "Statistics for quantity field";
analyze Sales quantity statistics;
print "";

print "Relationship between quantity and revenue";
analyze Sales quantity correlation(revenue);
print "";

print "90th percentile of revenue";
analyze Sales revenue percentile(90);
print "";

print "50th percentile (median) of price";
analyze Sales price percentile(50);
print "";

print "Row numbers for revenue";
analyze Sales revenue window(row_number, 15);
print "";

print "Ranking revenues (highest first)";
analyze Sales revenue window(rank, 15);
print "";

print "Dense ranking (no gaps)";
analyze Sales revenue window(dense_rank, 15);
print "";

print "Percent rank (0 to 1)";
analyze Sales revenue window(percent_rank, 15);
print "";

