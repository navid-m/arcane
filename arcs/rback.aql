create forced unique bucket Puddles (
    x: float,
    y: float
);

begin!;
    insert into Puddles (x: 12.2, y: 4.5);
    insert into Puddles (
        [x: 14.4, y: 42.5],
        [x: 20.2, y: 3.1],
        [x: 4.0, y: 2.3]
    );
rollback!;

begin!;
    insert into Puddles (
        [x: 15.4, y: 45.8],
        [x: 21.2, y: 3.2],
        [x: 4.5, y: 2.4]
    );
commit!;
